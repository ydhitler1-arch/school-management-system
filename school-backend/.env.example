# Copy this file to .env and fill in your real values.
# .env should NEVER be committed to git or shared.

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/schoolDB?retryWrites=true&w=majority
PORT=5000

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Your Vercel frontend URL (no trailing slash)
# Example: https://school-management.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Email (Nodemailer) — for overdue fee notifications
# Use a Gmail address + App Password (not your regular Gmail password)
# Generate App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-school-email@gmail.com
SMTP_PASS=your-gmail-app-password
